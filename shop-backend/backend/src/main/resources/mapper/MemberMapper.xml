<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shop.backend.mapper.MemberMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.shop.backend.entity.Member">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="level" property="level" />
        <result column="level_name" property="levelName" />
        <result column="points" property="points" />
        <result column="growth" property="growth" />
        <result column="total_spend" property="totalSpend" />
        <result column="checkin_date" property="checkinDate" />
        <result column="continuous_checkin" property="continuousCheckin" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, user_id, level, level_name, points, growth, total_spend, checkin_date, continuous_checkin
    </sql>

</mapper>
