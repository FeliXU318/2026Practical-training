.wallet-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  background: #f4f7fb;
}

.balance-card {
  overflow: hidden;
  padding: 36rpx 34rpx 30rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #596fdc 0%, #7653b5 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(85, 91, 186, 0.24);
}

.balance-label {
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
}

.balance-value {
  margin-top: 12rpx;
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  line-height: 1.2;
}

.balance-value::before {
  content: '¥';
  margin-right: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.balance-metrics {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.18);
}

.balance-metric {
  display: flex;
  width: 50%;
  align-items: center;
  flex-direction: column;
}

.metric-divider {
  width: 1rpx;
  height: 58rpx;
  background: rgba(255, 255, 255, 0.2);
}

.metric-value {
  font-size: 30rpx;
  font-weight: 700;
}

.metric-label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 21rpx;
}

.wallet-section {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(35, 45, 72, 0.06);
}

.section-title {
  color: #252a34;
  font-size: 30rpx;
  font-weight: 800;
}

.amount-label {
  margin-top: 30rpx;
  color: #7c8490;
  font-size: 23rpx;
}

.amount-field {
  display: flex;
  min-width: 0;
  height: 102rpx;
  align-items: center;
  border-bottom: 1rpx solid #e8ebf0;
}

.currency {
  color: #252a34;
  font-size: 42rpx;
  font-weight: 700;
}

.amount-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  margin-left: 14rpx;
  color: #222832;
  font-size: 44rpx;
  font-weight: 700;
}

.all-action {
  flex: 0 0 auto;
  padding: 18rpx 0 18rpx 20rpx;
  color: #6079ea;
  font-size: 24rpx;
  font-weight: 700;
}

.withdraw-hint {
  margin-top: 14rpx;
  color: #a0a6af;
  font-size: 21rpx;
}

.account-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 30rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid #f0f2f5;
}

.account-title {
  color: #343a45;
  font-size: 25rpx;
  font-weight: 700;
}

.account-desc {
  margin-top: 6rpx;
  color: #a1a7b0;
  font-size: 21rpx;
}

.account-target {
  display: flex;
  align-items: center;
  color: #4d5562;
  font-size: 24rpx;
  font-weight: 600;
}

.wechat-dot {
  display: flex;
  width: 40rpx;
  height: 40rpx;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #17b869;
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 800;
}

.withdraw-button {
  display: flex;
  width: 100%;
  height: 82rpx;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #6079ea;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(96, 121, 234, 0.22);
}

.withdraw-button[disabled] {
  background: #d9deee;
  color: #ffffff;
  box-shadow: none;
}

.records-section {
  padding-bottom: 8rpx;
}

.record-row {
  display: flex;
  min-height: 116rpx;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #f0f2f5;
}

.records-section .section-title + .record-row {
  margin-top: 18rpx;
}

.record-icon {
  display: flex;
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
  align-items: center;
  justify-content: center;
  border-radius: 15rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.record-icon-income {
  background: #e6f8ed;
  color: #259b59;
}

.record-icon-withdraw {
  background: #edf0ff;
  color: #6079ea;
}

.record-copy {
  flex: 1;
  min-width: 0;
}

.record-title {
  color: #343a44;
  font-size: 26rpx;
  font-weight: 700;
}

.record-time {
  margin-top: 7rpx;
  color: #a3a9b2;
  font-size: 21rpx;
}

.record-amount {
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 800;
}

.record-amount.income {
  color: #23995a;
}

.record-amount.expense {
  color: #353b45;
}

.empty-state {
  padding: 46rpx 0;
  color: #a1a8b2;
  font-size: 24rpx;
  text-align: center;
}
