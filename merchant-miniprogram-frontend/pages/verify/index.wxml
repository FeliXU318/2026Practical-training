<view class="page-shell safe-bottom">
  <view class="verify-panel card">
    <view class="form-item">
      <text class="form-label">取货码</text>
      <input class="input code-input" value="{{code}}" bindinput="handleInput" placeholder="请输入 6 位取货码" maxlength="12" />
    </view>
    <view class="button-row">
      <button class="ghost-btn" bindtap="scanCode">扫码</button>
      <button class="primary-btn" loading="{{loading}}" bindtap="verifyCode">确认核销</button>
    </view>
  </view>

  <view class="result-card card" wx:if="{{result}}">
    <view class="section-title">核销结果</view>
    <view class="result-line"><text>订单号</text><text>#{{result.orderNo}}</text></view>
    <view class="result-line"><text>客户</text><text>{{result.customer}}</text></view>
    <view class="result-line"><text>商品</text><text>{{result.itemSummary}}</text></view>
    <view class="result-line"><text>金额</text><text class="strong">¥{{result.amount}}</text></view>
    <text class="status-badge status-completed">已完成</text>
  </view>
</view>
