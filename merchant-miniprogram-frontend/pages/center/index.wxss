.center-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 48rpx;
  background: #f4f7fb;
}

.merchant-hero {
  display: flex;
  min-height: 164rpx;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx 30rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #6078e6 0%, #7c4eaa 100%);
  box-shadow: 0 14rpx 30rpx rgba(91, 87, 190, 0.22);
}

.merchant-avatar {
  display: flex;
  flex: 0 0 auto;
  width: 94rpx;
  height: 94rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
}

.merchant-identity {
  flex: 1;
  min-width: 0;
}

.merchant-name {
  overflow: hidden;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.merchant-location {
  overflow: hidden;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.merchant-phone {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}

.merchant-badge {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 22rpx;
}

.business-overview {
  display: flex;
  min-height: 132rpx;
  align-items: center;
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: #414a59;
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(45, 55, 72, 0.14);
}

.overview-copy {
  flex: 1;
  min-width: 0;
}

.overview-title {
  font-size: 30rpx;
  font-weight: 800;
}

.overview-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
  color: #cdd3dc;
  font-size: 22rpx;
}

.overview-status.closed {
  color: #e2e6ec;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #55d98b;
  box-shadow: 0 0 0 5rpx rgba(85, 217, 139, 0.14);
}

.overview-status.closed .status-dot {
  background: #aeb6c2;
  box-shadow: 0 0 0 5rpx rgba(174, 182, 194, 0.16);
}

.overview-metric {
  display: flex;
  flex: 0 0 138rpx;
  min-width: 0;
  min-height: 70rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border-left: 1rpx solid rgba(255, 255, 255, 0.14);
}

.overview-value {
  overflow: hidden;
  max-width: 130rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.overview-label {
  margin-top: 8rpx;
  color: #cdd3dc;
  font-size: 21rpx;
}

.center-section {
  overflow: hidden;
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(35, 45, 72, 0.06);
}

.section-header {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

.section-heading {
  color: #232832;
  font-size: 30rpx;
  font-weight: 800;
}

.section-link {
  color: #a2a8b2;
  font-size: 24rpx;
}

.order-status-grid {
  display: flex;
  padding: 10rpx 10rpx 28rpx;
}

.order-status-item {
  display: flex;
  width: 25%;
  min-width: 0;
  align-items: center;
  flex-direction: column;
}

.status-icon {
  display: flex;
  width: 48rpx;
  height: 48rpx;
  align-items: center;
  justify-content: center;
}

.status-icon-image {
  width: 44rpx;
  height: 44rpx;
}

.status-count {
  margin-top: 12rpx;
  color: #252a34;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.status-label {
  margin-top: 9rpx;
  color: #737b88;
  font-size: 22rpx;
  white-space: nowrap;
}

.feature-list {
  padding: 0 28rpx 4rpx;
}

.feature-row {
  display: flex;
  min-height: 110rpx;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #f0f2f5;
}

.feature-icon {
  display: flex;
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  align-items: center;
  justify-content: center;
}

.feature-icon-image {
  width: 44rpx;
  height: 44rpx;
}

.feature-copy {
  flex: 1;
  min-width: 0;
}

.feature-title {
  color: #2a2f38;
  font-size: 28rpx;
  font-weight: 700;
}

.feature-desc {
  overflow: hidden;
  margin-top: 6rpx;
  color: #a0a6af;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feature-arrow {
  flex: 0 0 auto;
  color: #c7ccd3;
  font-size: 40rpx;
  line-height: 1;
}

.account-section {
  padding-bottom: 28rpx;
}

.account-row {
  display: flex;
  min-height: 84rpx;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 0 28rpx;
  border-top: 1rpx solid #f0f2f5;
}

.account-label {
  color: #767e89;
  font-size: 25rpx;
}

.account-value {
  overflow: hidden;
  max-width: 390rpx;
  color: #2a2f38;
  font-size: 25rpx;
  font-weight: 600;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.logout-button {
  display: flex;
  width: calc(100% - 56rpx);
  height: 78rpx;
  align-items: center;
  justify-content: center;
  margin: 18rpx 28rpx 0;
  border-radius: 14rpx;
  background: #fff1f0;
  color: #d64b45;
  font-size: 27rpx;
  font-weight: 700;
}
