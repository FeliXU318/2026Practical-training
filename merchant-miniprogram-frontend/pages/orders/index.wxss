.orders-page {
  min-height: 100vh;
  padding-top: 0;
  background: #f4f5f9;
}

.order-tabs {
  display: block;
  margin: 0 -28rpx 20rpx;
  padding: 0 12rpx;
  border-bottom: 1rpx solid #e9edf4;
  background: #ffffff;
  font-size: 0;
  white-space: nowrap;
}

.order-tab {
  display: inline-flex;
  position: relative;
  align-items: center;
  justify-content: center;
  width: 16.666666%;
  min-width: 0;
  min-height: 78rpx;
  padding: 0 2rpx;
  color: #636a76;
  font-size: 24rpx;
  line-height: 78rpx;
  vertical-align: top;
  white-space: nowrap;
}

.order-tab.active {
  color: #6578e8;
  font-weight: 800;
}

.order-tab.active::after {
  position: absolute;
  right: 2rpx;
  bottom: 0;
  left: 2rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #6578e8;
  content: "";
}

.order-card {
  overflow: hidden;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(26, 32, 52, 0.07);
}

.card-main {
  padding: 24rpx 24rpx 20rpx;
}

.shop-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.shop-avatar-wrap {
  flex: 0 0 78rpx;
  width: 78rpx;
  height: 78rpx;
}

.shop-avatar-img,
.shop-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  border-radius: 16rpx;
}

.shop-avatar-img {
  background: #f1f2f5;
}

.shop-avatar-placeholder {
  background: #7f4d2a;
  color: #fff8eb;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 78rpx;
}

.shop-main {
  flex: 1;
  min-width: 0;
}

.shop-title-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.shop-name {
  overflow: hidden;
  color: #202438;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chevron {
  flex: 0 0 auto;
  margin-left: 12rpx;
  color: #666a74;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.status-text {
  flex: 0 0 auto;
  margin-left: 12rpx;
  color: #6b6f78;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
  white-space: nowrap;
}

.status-text-pending,
.status-text-preparing,
.status-text-ready,
.status-text-delivery {
  color: #e19b1c;
}

.status-text-aftersale {
  color: #b35ad2;
}

.status-text-completed {
  color: #777b84;
}

.promo-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.promo-pill {
  display: inline-flex;
  align-items: center;
  max-width: 210rpx;
  height: 38rpx;
  padding: 0 14rpx;
  border: 1rpx solid #ef9ca0;
  border-radius: 8rpx;
  color: #df4f60;
  font-size: 24rpx;
  line-height: 38rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  margin-top: 26rpx;
}

.goods-preview {
  display: flex;
  position: relative;
  flex: 1;
  min-width: 0;
  gap: 22rpx;
}

.goods-item {
  flex: 0 1 168rpx;
  min-width: 0;
}

.goods-img,
.goods-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 168rpx;
  height: 128rpx;
  border-radius: 14rpx;
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 128rpx;
}

.goods-img {
  background: #f1f2f5;
}

.preview-tone-0 {
  background: linear-gradient(135deg, #f7b267, #d98b4d);
}

.preview-tone-1 {
  background: linear-gradient(135deg, #88c9a1, #4e9b78);
}

.preview-tone-2 {
  background: linear-gradient(135deg, #89a7f5, #596ed0);
}

.preview-tone-3 {
  background: linear-gradient(135deg, #f08cab, #cf5f76);
}

.preview-tone-4 {
  background: linear-gradient(135deg, #8fcbd6, #4f98a8);
}

.goods-name {
  display: block;
  overflow: hidden;
  margin-top: 14rpx;
  color: #555963;
  font-size: 30rpx;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-more {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-top: 32rpx;
  border-radius: 50%;
  background: #f0f2f6;
  color: #838894;
  font-size: 24rpx;
  font-weight: 800;
}

.order-summary {
  flex: 0 0 132rpx;
  padding-top: 74rpx;
  text-align: right;
}

.summary-price {
  color: #252934;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 48rpx;
  white-space: nowrap;
}

.summary-count {
  margin-top: 4rpx;
  color: #6f747e;
  font-size: 28rpx;
  line-height: 36rpx;
  white-space: nowrap;
}

.order-meta-line {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
  color: #aeb4c1;
  font-size: 24rpx;
  line-height: 32rpx;
}

.order-meta-line text {
  overflow: hidden;
  min-width: 0;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 18rpx 22rpx;
  border-top: 1rpx solid #eef1f7;
}

.outline-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 148rpx;
  height: 58rpx;
  padding: 0 26rpx;
  border: 2rpx solid #a7b3dd;
  border-radius: 999rpx;
  color: #6578a8;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.primary-outline {
  border-color: #8fa0da;
  color: #6076bd;
}

.empty {
  padding: 96rpx 24rpx;
  color: #b6bbc5;
  font-size: 26rpx;
  text-align: center;
}