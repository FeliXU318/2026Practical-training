.toolbar {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.search-box {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
  height: 76rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8dee9;
  border-radius: 14rpx;
  background: #ffffff;
}

.search-box input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 26rpx;
}

.search-icon {
  margin-right: 10rpx;
  color: #98a2b3;
  font-size: 30rpx;
}

.clear-btn {
  width: 44rpx;
  color: #98a2b3;
  font-size: 32rpx;
}

.add-btn {
  width: 144rpx;
  height: 76rpx;
}

.product-card {
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.product-main {
  display: flex;
  gap: 18rpx;
}

.product-thumb {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  border-radius: 16rpx;
  color: #172033;
  font-size: 40rpx;
  font-weight: 800;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.product-name {
  overflow: hidden;
  max-width: 330rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.product-data {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f7f9fc;
}

.data-label {
  display: block;
  color: #667085;
  font-size: 22rpx;
}

.data-value {
  display: block;
  margin-top: 6rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
}

.product-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.action-edit {
  min-width: 112rpx;
}

.tone-orange {
  background: linear-gradient(135deg, #fff1d6, #ffd591);
}

.tone-blue {
  background: linear-gradient(135deg, #e6f4ff, #91caff);
}

.tone-green {
  background: linear-gradient(135deg, #eaf8ef, #95de64);
}

.tone-pink {
  background: linear-gradient(135deg, #fff0f6, #ffadd2);
}

.tone-purple {
  background: linear-gradient(135deg, #f9f0ff, #d3adf7);
}

/* list-first refinement */
.product-card {
  margin-bottom: 0;
  padding: 24rpx 4rpx;
  border-width: 0 0 1rpx;
  border-color: #edf1f7;
  border-radius: 0;
  box-shadow: none;
}

.product-data {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 0;
  background: transparent;
}

.product-actions {
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1f7;
}

/* icon polish */
.product-thumb {
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.65);
}

.product-name::before {
  color: #1677ff;
  content: '货 ';
}

/* customer-app visual alignment */
.toolbar {
  gap: 16rpx;
}

.search-box {
  height: 78rpx;
  border: 0;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(35, 45, 72, 0.05);
}

.add-btn {
  width: 142rpx;
  height: 78rpx;
  border-radius: 999rpx;
}

.product-card {
  margin-bottom: 18rpx;
  padding: 26rpx 24rpx;
  border: 0;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(35, 45, 72, 0.06);
}

.product-thumb {
  border-radius: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(35, 45, 72, 0.10);
}

.product-name {
  color: #20242b;
  font-size: 31rpx;
}

.product-desc,
.data-label {
  color: #9aa1ad;
}

.product-data {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f0f2f6;
}

.data-value {
  color: #20242b;
}

.product-actions {
  border-top: 1rpx solid #f0f2f6;
}

.product-thumb-image {
  display: block;
  background: #f2f4f7;
}

.product-tabs {
  display: block;
  margin-right: -28rpx;
  margin-left: -28rpx;
  padding: 0 12rpx;
  border-bottom: 1rpx solid #e9edf4;
  background: #ffffff;
  font-size: 0;
  white-space: nowrap;
}

.product-tab {
  display: inline-flex;
  position: relative;
  align-items: center;
  justify-content: center;
  width: 33.333333%;
  min-height: 78rpx;
  color: #636a76;
  font-size: 28rpx;
  line-height: 78rpx;
  vertical-align: top;
}

.product-tab.active {
  color: #6578e8;
  font-weight: 800;
}

.product-tab.active::after {
  position: absolute;
  right: 30%;
  bottom: 0;
  left: 30%;
  height: 6rpx;
  border-radius: 999rpx;
  background: #6578e8;
  content: "";
}
