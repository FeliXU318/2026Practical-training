<view class="page-shell safe-bottom" wx:if="{{order}}">
  <view class="section card timeline-card">
    <view class="section-title">订单进度</view>
    <view class="timeline">
      <view class="timeline-step {{item.done ? 'done' : ''}} {{item.active ? 'active' : ''}}" wx:for="{{timeline}}" wx:key="status">
        <view class="dot"></view>
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="section card info-card">
    <view class="section-title">收货信息</view>
    <view class="info-row"><text>用户</text><text>{{order.customer}}</text></view>
    <view class="info-row"><text>电话</text><text>{{order.phone}}</text></view>
    <view class="info-row"><text>地址</text><text>{{order.address}}</text></view>
    <view class="info-row" wx:if="{{order.pickupCode}}"><text>取货码</text><text class="strong">{{order.pickupCode}}</text></view>
    <view class="remark" wx:if="{{order.displayRemark}}">备注：{{order.displayRemark}}</view>
  </view>

  <view class="section card info-card">
    <view class="section-title">商品明细</view>
    <view class="receipt-table">
      <view class="receipt-row receipt-head">
        <text class="receipt-product">产品</text>
        <text class="receipt-price">单价</text>
        <text class="receipt-count">数量</text>
        <text class="receipt-total">小计</text>
      </view>
      <view class="receipt-row receipt-line" wx:for="{{order.items}}" wx:key="name">
        <text class="receipt-product">{{item.name}}</text>
        <text class="receipt-price" wx:if="{{item.unitPriceText}}">¥{{item.unitPriceText}}</text>
        <text class="receipt-price muted" wx:else>-</text>
        <text class="receipt-count">{{item.count}}</text>
        <text class="receipt-total" wx:if="{{item.totalPriceText}}">¥{{item.totalPriceText}}</text>
        <text class="receipt-total muted" wx:else>-</text>
      </view>
      <view class="receipt-row receipt-grand-total">
        <text class="receipt-grand-label">总计</text>
        <text class="receipt-grand-value">¥{{order.itemsTotalText}}</text>
      </view>
    </view>
    <view class="divider"></view>
    <view class="info-row"><text>优惠</text><text>- ¥{{order.discount}}</text></view>
    <view class="info-row total"><text>应收</text><text>¥{{order.amount}}</text></view>
  </view>

  <view class="fixed-actions" wx:if="{{actions.length}}">
    <button class="{{item.primary ? 'primary-btn' : 'ghost-btn'}}" wx:for="{{actions}}" wx:key="status" data-status="{{item.status}}" bindtap="handleAction">
      {{item.text}}
    </button>
  </view>
</view>
